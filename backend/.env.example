# MongoDB Atlas connection string (required)
MONGO_URL="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority"
DB_NAME="decorous"

# Comma-separated list of allowed origins. Never set this to "*" — the app
# refuses to boot if allow_credentials=True and CORS_ORIGINS contains "*".
CORS_ORIGINS="https://decorous.in,https://app.decorous.in"

# Admin dashboard password (required, min 8 chars)
ADMIN_PASSWORD="change-me"

# ERP JWT signing secret (required, min 32 chars)
ERP_JWT_SECRET="change-me-to-a-random-32-plus-character-string"

# Resend API key for transactional email (optional — email sending is a no-op without it)
RESEND_API_KEY=""
NOTIFICATION_EMAIL="contact@decorous.in"
WHATSAPP_NUMBER="917008863329"
